# Environment
NODE_ENV=development

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Licenses
NEXT_PUBLIC_LG_LICENSE_KEY=

# Security
ENCRYPTION_KEY=

# Redis
REDIS_ENABLED=true
REDIS_URL=

# Download Rate Limiting (legacy full/part downloads)
DOWNLOAD_ALL_RATE_LIMIT=100
DOWNLOAD_PART_RATE_LIMIT_PER_COLLECTION=100
DOWNLOAD_LEGACY_RATE_LIMIT_WINDOW=14400000

# Download Stream Rate Limiting
DOWNLOAD_STREAM_RATE_LIMIT=6
DOWNLOAD_STREAM_RATE_LIMIT_WINDOW=3600000

# Contact Rate Limiting
CONTACT_RATE_LIMIT=10
CONTACT_RATE_LIMIT_WINDOW=3600000
CONTACT_IDENTITY_RATE_LIMIT=3
CONTACT_IDENTITY_RATE_LIMIT_WINDOW=86400000

# Email
EMAIL=contact@mogz.studio
# Use a verified sender on your Resend domain, e.g. website@mogz.studio
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Booking Session
NEXT_PUBLIC_BOOKING_SESSION_KEY=mogz_booking_draft

# Booking Rate Limiting
BOOKING_RATE_LIMIT_IP=5
BOOKING_RATE_LIMIT_WINDOW=3600000
BOOKING_IDENTITY_RATE_LIMIT=3
BOOKING_IDENTITY_RATE_LIMIT_WINDOW=43200000
BOOKING_DUPLICATE_RATE_LIMIT=1
BOOKING_DUPLICATE_RATE_LIMIT_WINDOW=300000
